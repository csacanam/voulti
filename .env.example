# =============================================
# Voulti Monorepo - Environment Variables
# =============================================
# Copy this file to .env in each app/contract directory that needs it.
# Each app has its own .env — see individual .env.example files.

# -- apps/api --
# PORT=3000
# SUPABASE_URL=
# SUPABASE_KEY=
# BACKEND_PRIVATE_KEY=           # Wallet with ONBOARDING_ROLE on all chains (also used as hot wallet for gas)
# HD_WALLET_MNEMONIC=            # BIP-39 mnemonic for generating deposit addresses
# SWEEP_POLL_INTERVAL_MS=15000   # How often to check for deposits (ms)
# SWEEP_MAX_RETRIES=5            # Max retry attempts for failed sweeps
# OPENEXCHANGERATES_APP_ID=
# COINGECKO_API_KEY=

# RPC URLs (optional, defaults to public RPCs)
# CELO_RPC_URL=https://forno.celo.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# POLYGON_RPC_URL=https://polygon-rpc.com
# BASE_RPC_URL=https://mainnet.base.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# Contract addresses per network (populated after deployment)
# CELO_PROXY_ADDRESS=
# CELO_STORAGE_ADDRESS=
# CELO_ACCESS_MANAGER_ADDRESS=
# CELO_INVOICE_MANAGER_ADDRESS=
# CELO_PAYMENT_PROCESSOR_ADDRESS=
# ARBITRUM_PROXY_ADDRESS=
# ARBITRUM_STORAGE_ADDRESS=
# ARBITRUM_ACCESS_MANAGER_ADDRESS=
# ARBITRUM_INVOICE_MANAGER_ADDRESS=
# ARBITRUM_PAYMENT_PROCESSOR_ADDRESS=
# POLYGON_PROXY_ADDRESS=
# POLYGON_STORAGE_ADDRESS=
# POLYGON_ACCESS_MANAGER_ADDRESS=
# POLYGON_INVOICE_MANAGER_ADDRESS=
# POLYGON_PAYMENT_PROCESSOR_ADDRESS=
# BASE_PROXY_ADDRESS=
# BASE_STORAGE_ADDRESS=
# BASE_ACCESS_MANAGER_ADDRESS=
# BASE_INVOICE_MANAGER_ADDRESS=
# BASE_PAYMENT_PROCESSOR_ADDRESS=
# BSC_PROXY_ADDRESS=
# BSC_STORAGE_ADDRESS=
# BSC_ACCESS_MANAGER_ADDRESS=
# BSC_INVOICE_MANAGER_ADDRESS=
# BSC_PAYMENT_PROCESSOR_ADDRESS=

# -- apps/checkout --
# VITE_BACKEND_URL=http://127.0.0.1:3000
# VITE_WALLETCONNECT_PROJECT_ID=
# Hardhat local (auto-generated by setup-local script)
# VITE_HARDHAT_PROXY_ADDRESS=
# VITE_HARDHAT_STORAGE_ADDRESS=
# VITE_HARDHAT_ACCESS_MANAGER_ADDRESS=
# VITE_HARDHAT_INVOICE_MANAGER_ADDRESS=
# VITE_HARDHAT_PAYMENT_PROCESSOR_ADDRESS=
# VITE_HARDHAT_USDC_ADDRESS=
# VITE_HARDHAT_USDT_ADDRESS=

# -- apps/merchant --
# NEXT_PUBLIC_PRIVY_APP_ID=
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
