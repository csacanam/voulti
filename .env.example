# =============================================
# Voulti - Environment Variables
# =============================================

# -- apps/api (DigitalOcean) --
# PORT=8080
# SUPABASE_URL=https://your-instance.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
# PRIVATE_KEY=your_voulti_operator_private_key
# BACKEND_PRIVATE_KEY=your_voulti_operator_private_key  (same as PRIVATE_KEY)
# HD_WALLET_MNEMONIC=your_12_word_mnemonic_for_deposit_addresses
# PRIVY_APP_ID=your_privy_app_id
# PRIVY_APP_SECRET=your_privy_app_secret
# RESEND_APIKEY=your_resend_api_key
# ALLOWED_ORIGINS=https://voulti.com,https://app.voulti.com
# SWEEP_POLL_INTERVAL_MS=15000
# SWEEP_MAX_RETRIES=5

# RPC URLs (optional — defaults to public RPCs)
# CELO_RPC_URL=https://forno.celo.org
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
# POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
# BASE_RPC_URL=https://mainnet.base.org
# BSC_RPC_URL=https://bsc-dataseed.binance.org

# -- apps/checkout (Vercel: voulti.com) --
# VITE_BACKEND_URL=https://api.voulti.com
# VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# -- apps/merchant (Vercel: app.voulti.com) --
# NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
# NEXT_PUBLIC_API_BASE_URL=https://api.voulti.com/api
# NEXT_PUBLIC_CHECKOUT_URL=https://voulti.com
